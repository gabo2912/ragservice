# ───────────────────────────────────────────────────────────────
# Configuración del servidor RAG
# ───────────────────────────────────────────────────────────────
# Copiar a .env y ajustar según necesidad:
#   cp .env.example .env
# ───────────────────────────────────────────────────────────────

# Puerto donde corre el servidor FastAPI
RAG_PORT=8001
RAG_HOST=127.0.0.1

# Modo activo del responder:
#   simple → Camino B (retrieval con framing textual, sin LLM)
#   llm    → Camino A (síntesis con phi3.5 vía Ollama, requiere setup adicional)
RAG_MODO_DEFAULT=simple

# Threshold de distancia coseno (menor = más relevante).
# Si el mejor chunk supera este threshold, se considera que la pregunta
# no tiene buena respuesta en el PDF y se devuelve respuesta=null.
RAG_SCORE_THRESHOLD=0.62

# Modelo de embeddings.
# Por defecto usa el nombre corto del modelo en HuggingFace; sentence-transformers
# lo descarga automáticamente y lo cachea en ~/.cache/huggingface/.
# Si tu red bloquea HuggingFace o querés trabajar offline, podés pasar una RUTA
# LOCAL ABSOLUTA a una carpeta con el modelo descargado, ej:
#   RAG_EMBED_MODEL=/Users/gabriel/modelos/paraphrase-multilingual-MiniLM-L6-v2
RAG_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# Parámetros de chunking (solo relevantes para indexer.py).
# CHUNK_SIZE más bajo = chunks más enfocados = mejor calidad de respuesta
# pero más chunks totales en el índice. Si lo cambias, hay que re-indexar.
RAG_CHUNK_SIZE=600
RAG_CHUNK_OVERLAP=100

# Configuración del Camino A (LLM). Solo se usa si RAG_MODO_DEFAULT=llm
# o si la request explícita pide modo="llm".
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3.5:latest
OLLAMA_TIMEOUT=60
OLLAMA_TEMPERATURE=0.3


# Recuperación multi-chunk (mejora de calidad)
RAG_RETRIEVE_K=4
RAG_COMBINAR_TOP_N=2
RAG_RESPUESTA_MAX_CHARS=700

ANONYMIZED_TELEMETRY=False